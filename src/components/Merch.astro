---
import SectionLabel from './SectionLabel.astro';
import { t } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'en';
const tr   = t(lang).merch;
---
<section id="merch" class="border-t border-edge">
  <div class="max-w-6xl mx-auto px-6 md:px-16 py-28 reveal">
    <SectionLabel label={tr.sectionLabel} />
    <h2 class="font-heading leading-none tracking-[0.02em]" style="font-size: clamp(2.8rem, 5.5vw, 4.8rem);">
      {tr.heading}
    </h2>

    <div class="relative mt-12 bg-surface border border-edge overflow-hidden flex flex-col md:flex-row items-start md:items-center justify-between gap-8 p-10 md:p-16">
      <div
        class="absolute font-heading text-white pointer-events-none select-none"
        style="right:-2rem; top:50%; transform:translateY(-50%); font-size:14rem; opacity:0.02; line-height:1; white-space:nowrap; letter-spacing:-0.02em;"
        aria-hidden="true"
      >
        MERCH
      </div>

      <div class="relative">
        <h3 class="font-heading text-[3rem] leading-none mb-2">{tr.dropHeading}</h3>
        <p class="text-dim text-[0.92rem] leading-[1.7] max-w-sm">{tr.dropBody}</p>
        <span class="btn-primary mt-6 inline-block opacity-50 cursor-not-allowed select-none">{tr.shopNow}</span>
      </div>

      <div class="relative flex gap-4 flex-wrap">
        {['👕', '🧢', '🖤'].map(icon => (
          <div class="merch-icon w-24 h-24 bg-raised border border-edge flex items-center justify-center text-[2.2rem]">
            {icon}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .merch-icon { transition: border-color 0.2s; }
  .merch-icon:hover { border-color: var(--color-brand); }
</style>
