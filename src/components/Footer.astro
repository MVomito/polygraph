---
import { t } from '../i18n/translations';

const lang    = Astro.currentLocale ?? 'en';
const tr      = t(lang);
const base    = import.meta.env.BASE_URL.replace(/\/$/, '');
const langUrl = base + tr.nav.langUrl;

const socials = [
  { label: 'Instagram', href: 'https://www.instagram.com/polygraph_official/'                },
  { label: 'Spotify',   href: 'https://open.spotify.com/artist/66livGMtCgTyUwWbj5lXGw'      },
  { label: 'YouTube',   href: 'https://www.youtube.com/channel/UCKFL0qVALvSjHZ0Vk4Wfk_Q'   },
  { label: 'TikTok',    href: 'https://www.tiktok.com/@polygraphband'                        },
  { label: 'Facebook',  href: 'https://www.facebook.com/PolygraphQc'                        },
];
---
<footer class="bg-[#050505] border-t border-edge px-6 md:px-16 py-10 flex flex-wrap items-center justify-between gap-6">
  <div class="font-heading text-[2rem] tracking-[0.1em]">
    POLY<span class="text-brand">G</span>RAPH
  </div>

  <nav aria-label="Social links" class="flex flex-wrap gap-6 md:gap-8">
    {socials.map(({ label, href }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[0.62rem] tracking-[0.1em] uppercase text-dim hover:text-brand transition-colors duration-200 no-underline"
      >
        {label}
      </a>
    ))}
  </nav>

  <!-- Language switcher in footer -->
  <div class="flex items-center gap-3">
    <a
      href={langUrl}
      class="font-mono text-[0.62rem] tracking-widest uppercase text-dim border border-dim px-2 py-1 no-underline hover:text-brand hover:border-brand transition-all duration-200"
    >
      {tr.nav.langSwitch}
    </a>
    <p class="font-mono text-[0.58rem] tracking-[0.08em] text-dim opacity-40">
      {tr.footer.rights}
    </p>
  </div>
</footer>
