---
import SectionLabel from './SectionLabel.astro';
import { t } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'en';
const tr   = t(lang).about;
const b    = import.meta.env.BASE_URL;

const members = tr.members;

const memberColor: Record<string, string> = {
  Thomas:    '#39ff14',
  Alexandre: '#39ff14',
  'J-P':     '#39ff14',
};
---
<section id="about">

  <!-- Full-bleed band photo with heading overlay -->
  <div class="relative overflow-hidden" style="height: 75vh; min-height: 480px;">
    <img
      src={`${b}band-photo.jpg`}
      alt="Polygraph — full band"
      class="absolute inset-0 w-full h-full object-cover"
      style="object-position: center 15%;"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(8,8,8,0.35) 0%, transparent 35%, rgba(8,8,8,0.92) 100%);"></div>

    <!-- Label pinned to bottom of photo -->
    <div class="absolute bottom-0 left-0 right-0 px-6 md:px-16 pb-12">
      <SectionLabel label={tr.sectionLabel} />
    </div>
  </div>

  <!-- Stats bar -->
  <div class="border-b border-edge" style="background: #0d0d0d;">
    <div class="max-w-6xl mx-auto px-6 md:px-16">
      <div class="grid grid-cols-3 divide-x divide-edge">
        {tr.stats.map(({ num, label }) => (
          <div class="py-8 md:py-10 px-2 md:px-6 text-center">
            <div class="font-heading leading-none text-brand" style="font-size: clamp(2rem, 5vw, 3.5rem);">{num}</div>
            <div class="font-mono text-[0.58rem] tracking-[0.2em] uppercase text-dim mt-2">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bio + Members -->
  <div class="max-w-6xl mx-auto px-6 md:px-16 py-24 reveal">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Bio text -->
      <div>
        <p class="text-[1.2rem] font-semibold leading-[1.55] mb-5">{tr.intro}</p>
        <p class="text-dim leading-[1.9] mb-4">{tr.body[0]}</p>
        <p class="text-dim leading-[1.9]">{tr.body[1]}</p>
      </div>

      <!-- Members roster -->
      <div class="border-t border-edge">
        {members.map(({ name, role }) => (
          <div class="member-row group flex items-center gap-4 border-b border-edge py-4 px-2 cursor-default" style={`--hc: ${memberColor[name] ?? '#ff1493'};`}>
            <span class="member-name font-heading text-[1.6rem] leading-none tracking-[0.04em] flex-1 transition-colors duration-200">
              {name}
            </span>
            <span class="font-mono text-[0.55rem] tracking-[0.2em] uppercase text-dim group-hover:text-white/60 transition-colors duration-200">
              {role}
            </span>
          </div>
        ))}
      </div>

    </div>
  </div>

</section>

<style>
  .member-row { transition: background 0.15s; }
  .member-row:hover { background: rgba(255,255,255,0.03); }
  .member-row:hover .member-name { color: var(--hc); }
</style>
