---
import SectionLabel from './SectionLabel.astro';
import { t } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'en';
const tr   = t(lang).about;

const members = tr.members;
---
<section id="about" class="border-t border-edge">
  <div class="max-w-6xl mx-auto px-6 md:px-16 py-28 reveal">
    <SectionLabel label={tr.sectionLabel} />
    <h2 class="font-heading leading-none tracking-[0.02em]" style="font-size: clamp(2.8rem, 5.5vw, 4.8rem);">
      {tr.heading[0]}<br />{tr.heading[1]}
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 mt-12 items-start">
      <!-- Band photo -->
      <div class="relative">
        <div class="w-full overflow-hidden relative" style="aspect-ratio: 16/9;">
          <img
            src="/band-photo.jpg"
            alt="Polygraph — full band"
            class="w-full h-full object-cover object-center"
          />
          <div
            class="absolute pointer-events-none"
            style="top:-8px; left:-8px; right:8px; bottom:8px; border:1px solid #ff1493; opacity:0.25;"
          ></div>
        </div>
        <div
          class="absolute"
          style="bottom:-14px; right:-14px; width:55px; height:55px; border-right:2px solid #ff1493; border-bottom:2px solid #ff1493;"
        ></div>
      </div>

      <!-- Text -->
      <div>
        <p class="text-[1.15rem] font-semibold leading-[1.55] mb-4">{tr.intro}</p>
        <p class="text-dim leading-[1.85] mb-8">
          {tr.body[0]}<br /><br />{tr.body[1]}
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-edge">
          {tr.stats.map(({ num, label }) => (
            <div>
              <div class="font-heading text-[2.8rem] leading-none text-accent">{num}</div>
              <div class="font-mono text-[0.58rem] tracking-[0.18em] uppercase text-dim mt-1">{label}</div>
            </div>
          ))}
        </div>

        <!-- Members -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-6">
          {members.map(({ name, role }) => (
            <div class="member-card bg-surface border border-edge p-4 text-center">
              <div class="w-12 h-12 rounded-full bg-raised border border-edge mx-auto mb-3"></div>
              <div class="font-heading text-base tracking-[0.05em]">{name}</div>
              <div class="font-mono text-[0.52rem] tracking-[0.15em] uppercase text-brand mt-1">
                {role}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .member-card {
    transition: border-color 0.2s, transform 0.25s;
  }
  .member-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-3px);
  }
</style>
