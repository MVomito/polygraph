---
import { t } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'en';
const tr   = t(lang).hero;
const b    = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden px-6"
>
  <!-- Slideshow bg -->
  <div class="absolute inset-0 pointer-events-none" style="z-index:0;" aria-hidden="true">
    <img src={`${b}/hero-bg.jpg`}   alt="" class="hero-slide absolute inset-0 w-full h-full object-cover object-center" style="opacity:1; transition:opacity 0.9s ease-in-out;" />
    <img src={`${b}/hero-bg-4.jpg`} alt="" class="hero-slide absolute inset-0 w-full h-full object-cover" style="opacity:0; transition:opacity 0.9s ease-in-out; object-position: center 25%;" />
    <img src={`${b}/hero-bg-5.jpg`} alt="" class="hero-slide absolute inset-0 w-full h-full object-cover object-center" style="opacity:0; transition:opacity 0.9s ease-in-out;" />
    <img src={`${b}/hero-bg-6.jpg`} alt="" class="hero-slide absolute inset-0 w-full h-full object-cover object-center" style="opacity:0; transition:opacity 0.9s ease-in-out;" />
    <img src={`${b}/hero-bg-7.jpg`} alt="" class="hero-slide absolute inset-0 w-full h-full object-cover object-center" style="opacity:0; transition:opacity 0.9s ease-in-out;" />
    <img src={`${b}/hero-bg-8.jpg`} alt="" class="hero-slide absolute inset-0 w-full h-full object-cover object-center" style="opacity:0; transition:opacity 0.9s ease-in-out;" />
  </div>
  <!-- Dark overlay -->
  <div class="absolute inset-0 pointer-events-none" style="background: rgba(0,0,0,0.48); z-index:1;"></div>

  <!-- Grid bg -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(rgba(255,20,147,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(57,255,20,0.03) 1px, transparent 1px); background-size: 80px 80px; z-index:2;"
  ></div>

  <!-- Radial glow -->
  <div
    class="absolute rounded-full pointer-events-none"
    style="width:700px; height:700px; background: radial-gradient(circle, rgba(255,20,147,0.12) 0%, rgba(57,255,20,0.04) 60%, transparent 75%); top:50%; left:50%; transform:translate(-50%,-50%); z-index:3;"
  ></div>

  <!-- Content above overlays -->
  <div class="relative flex flex-col items-center text-center pt-20 pb-40" style="z-index: 4;">
    <p class="font-mono text-[0.7rem] tracking-[0.35em] uppercase text-brand mb-6">
      <span class="opacity-40">—</span>&ensp;{tr.label}&ensp;<span class="opacity-40">—</span>
    </p>

    <img
      src={`${b}/logo.png`}
      alt="POLYGRAPH"
      class="select-none pointer-events-none glitch-logo"
      style="width: min(95vw, 1200px); margin-top: -3rem; margin-bottom: -3rem;"
      draggable="false"
    />

    <p
      class="font-mono uppercase text-white/70 mt-4 mb-10"
      style="font-size: clamp(0.6rem, 1.4vw, 0.82rem); letter-spacing: 0.35em;"
    >
      {tr.tagline}
    </p>

    <div class="flex flex-wrap gap-6 justify-center">
      <a href="#music" class="btn-primary">{tr.listenNow}</a>
      <a href="#contact" class="btn-outline">{tr.bookShow}</a>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="z-index: 4;">
    <span class="font-mono text-[0.58rem] tracking-[0.25em] uppercase text-white/40">{tr.scroll}</span>
    <div
      class="w-px h-12"
      style="background: linear-gradient(to bottom, #ff1493, transparent); animation: scroll-pulse 2s ease-in-out infinite;"
    ></div>
  </div>
</section>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.hero-slide'));
  let current = 0;
  setInterval(() => {
    slides[current].style.opacity = '0';
    current = (current + 1) % slides.length;
    slides[current].style.opacity = '1';
  }, 4000);
</script>
