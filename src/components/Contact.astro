---
import SectionLabel from './SectionLabel.astro';
import { t } from '../i18n/translations';

const lang = Astro.currentLocale ?? 'en';
const tr   = t(lang).contact;
---
<section id="contact" class="border-t border-edge">
  <div class="max-w-6xl mx-auto px-6 md:px-16 py-28 reveal">
    <SectionLabel label={tr.sectionLabel} />
    <h2 class="font-heading leading-none tracking-[0.02em]" style="font-size: clamp(2.8rem, 5.5vw, 4.8rem);">
      {tr.heading[0]}<br />{tr.heading[1]}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 mt-12">
      <!-- Info -->
      <div>
        <h3 class="font-heading text-[2rem] mb-3">{tr.lede}</h3>
        <p class="text-dim leading-[1.8] mb-8 text-[0.95rem]">{tr.body}</p>
        <div class="flex flex-col gap-3">
          {tr.items.map(({ label, value }) => (
            <div class="px-4 py-3 bg-surface border border-edge" style="border-left: 2px solid #ff1493;">
              <div class="font-mono text-[0.57rem] tracking-[0.15em] uppercase text-dim">{label}</div>
              <div class="text-[0.9rem] mt-[2px]">{value}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Form — Formspree backend -->
      <form
        id="contact-form"
        action="https://formsubmit.co/millercoreagency@gmail.com"
        method="POST"
        class="flex flex-col gap-5"
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label class="font-mono text-[0.58rem] tracking-[0.15em] uppercase text-dim" for="fname">{tr.form.name}</label>
            <input id="fname" name="name" type="text" placeholder={tr.form.namePH} required
              class="bg-surface border border-edge text-white px-4 py-3 text-[0.9rem] focus:border-brand transition-colors duration-200" />
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-mono text-[0.58rem] tracking-[0.15em] uppercase text-dim" for="femail">{tr.form.email}</label>
            <input id="femail" name="email" type="email" placeholder={tr.form.emailPH} required
              class="bg-surface border border-edge text-white px-4 py-3 text-[0.9rem] focus:border-brand transition-colors duration-200" />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label class="font-mono text-[0.58rem] tracking-[0.15em] uppercase text-dim" for="ftype">{tr.form.type}</label>
          <select id="ftype" name="type" class="bg-surface border border-edge text-white px-4 py-3 text-[0.9rem] focus:border-brand transition-colors duration-200 cursor-pointer">
            <option value="">{tr.form.typeDefault}</option>
            {tr.form.typeOptions.map(opt => <option>{opt}</option>)}
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label class="font-mono text-[0.58rem] tracking-[0.15em] uppercase text-dim" for="fmsg">{tr.form.message}</label>
          <textarea id="fmsg" name="message" placeholder={tr.form.messagePH} style="min-height:120px; resize:vertical;"
            class="bg-surface border border-edge text-white px-4 py-3 text-[0.9rem] focus:border-brand transition-colors duration-200"></textarea>
        </div>

        <!-- Formsubmit config -->
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_subject" value="New booking inquiry — Polygraph" />
        <input type="text" name="_honey" style="display:none" />

        <button
          type="submit"
          id="submit-btn"
          class="btn-primary w-full mt-1"
        >
          {tr.form.submit}
        </button>

        <p id="form-status" class="font-mono text-[0.65rem] tracking-[0.1em] text-center hidden"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form   = document.getElementById('contact-form') as HTMLFormElement;
  const btn    = document.getElementById('submit-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = '...';

    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    });

    if (res.ok) {
      btn.textContent = 'Message Sent ✓';
      btn.style.background = '#2a9e58';
      status.textContent = 'We\'ll get back to you shortly.';
      status.style.color = '#39ff14';
      status.classList.remove('hidden');
      form.reset();
    } else {
      btn.textContent = 'Error — try again';
      btn.style.background = '#c0392b';
      btn.disabled = false;
      status.textContent = 'Something went wrong. Email us directly at millercoreagency@gmail.com';
      status.style.color = '#ff1493';
      status.classList.remove('hidden');
    }
  });
</script>
